-- draw

function _draw()
	-- clear screen to dark blue
	cls(bckc)
	
	map()
	drw_lns()
	drw_inf()
	drw_nt(0)
	drw_nt(2)
	--wait(40)
	--drw_nt(2)
	--drw_nt(2)
	

	if mknwnt==1 then
	 drw_nt(0)
	 drw_nt(1)
	 drw_nt(2)
	 wait(60)
	 --cls(bckc)
	 --drw_inf()
	 --drw_lns()
	 nwnt()
	 cls(bckc)
	 drw_inf()
	 drw_lns()
	 drw_nt(0)
	 drw_nt(2)
	 pnt(nt_a)
		wait(40)
		pnt(nt_b)
	 mknwnt=0
	end
end
-->8
--update 
function _update()
	if btnp(5) then
	--	nwnt()
	end
	if btnp(4) then
  		rpnt()
	end
	if btnp(0) then
		pnt(nt_a)
	end
		if btnp(1) then
		pnt(nt_b)
	end
	
	ans()
	
--instrument()	
end
