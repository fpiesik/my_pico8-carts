pico-8 cartridge // http://www.pico-8.com
version 35
__lua__

bckc=1
lns_x=13
lns_y=95
lns_w=100
lns_n=5
lns_s=8
lns_c=13
nt_x=lns_x+30
nt_xd=30

scl_act=0
ans_nOpt=2
ans_allOpt=0
ans_opt={0}

--menu functions
function scl_ch()
end
function nOpt()
end

function _init()
	-- make a custom menu item
	--menuitem(1, "Scale", scl_ch())
	menuitem(1, "+answers", function() 
		ans_nOpt+=1 
		if ans_nOpt>1 then ans_allOpt=0 end
	end)
	menuitem(2, "-answers", function() 
		ans_nOpt-=1
		if ans_nOpt<=1 then ans_nOpt=1 end
		if ans_nOpt==1 then ans_allOpt=1 end
	end)
	--menuitem(2, "show hints", display_hints)
	--menuitem(3, "foo"..ans_nOpt, function(b) if (b&1 > 0) then ans_nOpt+=1 end end)
	--menuitem(3, "foo", function(b) if (b&1 > 0) then printh("left was pressed") end end)
	nt_a=0
	nt_b=0
	nt_c=0
	nt_dff=0
	hts=0
	mss=0
	mknwnt=0	
	
	cls(bckc)
	map()
	nwnt()
 	drw_lns()
	drw_nt(0)
	drw_inf()
	rpnt()
	wait(40)
	drw_nt(2)
end

-->8
--draw functions

function drw_lns()
	x=lns_x
	y=lns_y
	w=lns_w
	s=lns_s
	c=lns_c
	n=lns_n
	for ln=0,n-1 do
  dblln(x,y-ln*s,w,c)	  
	end
	
	--key
	spr(4,x,y-s*n+2,4,6)
end	




function drw_nt(n)
	y=lns_y+s-s/2+1
	s=8
	w=30
	if n==0 then
	 x=nt_x
	 nv=nt_a
		np=nt_a*s/2
		ns=0
	end
	if n==1 then
  x=nt_x+nt_xd
  nv=nt_b
  np=nt_b*s/2
  ns=1
 end
 if n==2 then
  x=nt_x+nt_xd
  nv=ans_opt[nt_c+1]
  np=ans_opt[nt_c+1]*s/2
  ns=2	
 end
 
 if nv<1 then 
	 dblln(x-3,y+3,13,lns_c) 
	end
	if nv>11 then 
		dblln(x-3,y-s*6+3,13,lns_c) 
	end
	if nv>13 then 
	 dblln(x-3,y-s*7+3,13,lns_c) 
	end
 spr(ns,x,y-np,1,1)
end


function drw_inf()
	num=nt_dff
	str="what's the second note?"
	str2="dff: "..num
 	str_hts="hits: "..hts
 	str_mss="misses: "..mss
	str_len=#str
	str_scl=scl_act
	if ans_nOpt>1 then str_nOpt="possible Answers: "..ans_nOpt end
	if ans_nOpt==1 then str_nOpt="possible Answers: all" end
	-- print: str,x,y,col
	print(str, 60-str_len*2, 3, 7)
	print(str_hts, 20, 15, 7)
 	print(str_mss, 60, 15, 7)	
	print(str_nOpt,20,120,7)
end

function dblln(x,y,w,c)
 line(x,y,x+w,y,c)
	line(x,y+1,x+w,y+1,c)
end
-->8
function pnt(n)
 n=scl[n+1]
 sfx(0,-1,n,1)	
end

function wait(a)
 for i = 1,a 
 	do flip()
	end
end


-->8
--question answer


function nwnt()
	rng=scl_ln
	off=0
	nt_a=flr(rnd(rng)+off)	
	nt_b=flr(rnd(rng)+off) 
	nt_dff=nt_b-nt_a
	while (nt_a == nt_b) do  
		nt_b=flr(rnd(rng)+off) 
		nt_dff=nt_b-nt_a
	end
	mkOptn(ans_nOpt)
end

function mkOptn(nOpt)
	optHasAns=0
	if ans_allOpt==0 then
		ans_opt={0}
		while optHasAns == 0 do
			for i = 1,nOpt do 
				ans_opt[i]=flr(rnd(scl_ln/nOpt)+(i-1)*scl_ln/nOpt)
			end
			for a=1,nOpt do
				if ans_opt[a]==nt_b then optHasAns=1 end
			end
			for a=1,nOpt do
				if ans_opt[a]==nt_a then optHasAns=0 end
			end
		end
	end
	if ans_allOpt==1 then	
		for i = 1,scl_ln do 
			ans_opt[i]=i-1
		end
	end
end

function rpnt()
	pnt(nt_a)
	wait(40)
	pnt(nt_b)
end

	--answer
function ans()
	if btnp(2) then
		nt_c=nt_c+1
		if nt_c>=#ans_opt then nt_c=#ans_opt-1 end
	end
	if btnp(3) then
		nt_c=nt_c-1
		if nt_c<0 then nt_c=0 end
	end
	if btnp(5) then
	 if nt_b==ans_opt[nt_c+1] then
	  sfx(1)
			hts=hts+1
		end
	 if nt_b!=ans_opt[nt_c+1] then
	  sfx(2)
			mss=mss+1
		end
		mknwnt=1
	end
end


