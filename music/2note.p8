scl_c = {0,2,4,5,7,9,11,12}
scl_c2oct = {0,2,4,5,7,9,11,12,14,16,17,19,21,23,24}
--scl_ln = #scl_c
scl_ln = #scl_c2oct
scl = scl_c2oct


