pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
function _draw()
 cls()
 nt:dn(8,2,30,0)
 nt:dn(8,20,30,1)
end

nt={
 x=20,
 y=20,
	r8l=6,
	r8w=4,
	nr=2,
	nl=9,
	nfl=5,
	nfw=3,
	noff=4,
	pos=10,
	dn=function(s,val,x,y,flp)
		if(val==8 and flp==0)then
			circfill(x+s.noff+s.pos,y,s.nr,7)
			line(x+s.noff+s.pos+s.nr,y,x+s.noff+s.pos+s.nr,y-s.nl,7)
			line(x+s.noff+s.pos+s.nr,y-s.nl,x+s.noff+s.pos+s.nr+s.nfw,y-s.nl+s.nfl,7)
		end
		if(val==8 and flp==1)then
			circfill(x+s.noff+s.pos,y,s.nr,7)
			line(x+s.noff+s.pos-s.nr,y,x+s.noff+s.pos-s.nr,y+s.nl,7)
			line(x+s.noff+s.pos-s.nr,y+s.nl,x+s.noff+s.pos-s.nr+s.nfw,y+s.nl-s.nfl,7)
		end
	end,
	dr=function(s,val,x,y)
		if(val==8)then
			line(x+s.noff+s.pos+s.r8w/2,y-s.r8l/2,x+s.noff+s.pos-s.r8w/2+1,y+s.r8l/2,7)
			line(x+s.noff+s.pos+s.r8w/2,y-s.r8l/2,x+s.noff+s.pos-s.r8w/2,y-s.r8l/2+1,7)
		end
	end
	}



