pico-8 cartridge // http://www.pico-8.com
version 41
__lua__
-- piano roll music visualizer
-- by kittenm4ster

-- globals
note_width = 8
note_height = 5
max_notehistory = 128 / note_width


function _init()
  init_channel_models()

  -- load the music and sfx data from another cart
  --reload(0x3100, 0x3100, 0x1200, 'othercart.p8.png')

  -- permanently store the music and sfx data loaded above
  --cstore(0x3100, 0x3100, 0x1200)

		delayframes = 0
end

function init_channel_models()
  channels = {}
  for i = 1, 4 do
    channels[i] = {
      notehistory = {}
    }
  end

  channels[1].color = 8
  channels[2].color = 10
  channels[3].color = 12
  channels[4].color = 14
end

function _update60()
  if delayframes < 60 then
    delayframes += 1
  elseif delayframes == 60 then
    music(0)
    delayframes = 61
  end

  if btnp(4) then
    -- restart the song
    init_channel_models()
    music(0)
    delayframes = 61
  elseif btnp(5) then
    music(-1)
  end



  read_channels()

  local notechanged = false
  for channel in all(channels) do
    if channel.sfxindex > -1 and channel.hasaudiblenotes then
      -- if the note index changed
      if channel.noteindex ~= channel.prevnoteindex then
        channel.prevnoteindex = channel.noteindex
        notechanged = true
      end
    end
  end

  if notechanged then
    for channel in all(channels) do
      -- shift all notes in notehistory to the left in the array, overwriting the
      -- first item in the array
      for i = 2, max_notehistory do
        channel.notehistory[i - 1] = channel.notehistory[i]
      end

      if channel.sfxindex > -1 then
        -- put the new note on the end
        local note = channel.notes[channel.noteindex]
        channel.notehistory[max_notehistory] = note
      else
        channel.notehistory[max_notehistory] = nil
      end
    end
  end
end

function _draw()
  cls(1)

  for c, channel in pairs(channels) do
    local y = note_width

    -- use a highlight color for the active note
    color(7)

    for n = max_notehistory, 1, -1 do
      local note = channel.notehistory[n]

      if note and note.volume > 0 then
        local x = (note.pitch * note_height) - note_height

        rectfill(
          x, y,
          x + (note_height - 1), y + (note_width - 1))
      end

      y += note_width

      -- use the normal channel color for the rest of the notes in the
      -- channel
      color(channel.color)
    end
  end
  drw_keys(self)
end

function read_sfx_notes(sfxindex)
  local notes = {}

  -- find the address of the sfx (68 bytes per sfx)
  local sfxaddr = 0x3200 + (68 * sfxindex)

  for i = 0, 31 do
    -- find the address of the note (16 bits)
    local noteoffset = (i * 2)

    -- get the two bytes of the note
    local byte1 = peek(sfxaddr + noteoffset)
    local byte2 = peek(sfxaddr + noteoffset + 1)

    notes[i] = {
      pitch = band(byte1, 63),
      volume = shr(band(byte2, 14), 1)
    }
  end

  return notes
end

function read_channels()
  for i = 1, 4 do
    channels[i].noteindex = stat(45 + 4 + i)
    channels[i].sfxindex = stat(45 + i)

    if channels[i].sfxindex > -1 then
      channels[i].notes = read_sfx_notes(channels[i].sfxindex)

      for note in all(channels[i].notes) do
        if note.volume > 0 then
          channels[i].hasaudiblenotes = true
          break
        end
      end
    end
  end
end

function drw_keys(self) -- horizontal keyboard
 bw_pttn={0,1,0,1,0,0,1,0,1,0,1,0}
 w=note_height --width
 h=17 --height
 x=0 --x position
 y=128-h -- y position
 s=note_height -- key spacing
 for i = 0, 24 do
  if bw_pttn[i%12+1]==1 then
   clr=5
  else
   clr=7
  end  
  rectfill(x+s*i,y,x+s*i+w,y+h,clr)
 end
end

keymap={}
function upd_keys()

end

